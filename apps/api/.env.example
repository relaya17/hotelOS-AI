# Copy to apps/api/.env and fill in (never commit .env).
# Local API loads this file first, then falls back to repo-root .env.

NODE_ENV=development
API_PORT=3001
LOG_LEVEL=info

JWT_ACCESS_SECRET=change-me-access-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-min-16-chars

# Local file DB:
# DATABASE_URL=file:.data/hotelos.sqlite
# DATABASE_AUTH_TOKEN=

# Turso (production / Vercel) — paste from app.turso.tech:
DATABASE_URL=libsql://hotelos-prod-XXXX.aws-eu-west-1.turso.io
DATABASE_AUTH_TOKEN=

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,https://*.vercel.app
RECORDINGS_PATH=.data/recordings
NODEJS_HELPERS=0

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/trust/oauth/google/callback
GOOGLE_POST_LOGIN_REDIRECT=http://localhost:5173/
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=HotelOS AI

AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://api.openai.com/v1
AI_GATEWAY_MODEL=gpt-4o-mini
