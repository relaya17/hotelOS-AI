{
  "name": "hotelos",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@hotelos/api --filter=@hotelos/executive --filter=@hotelos/admin --filter=@hotelos/guest",
    "dev:api": "turbo run dev --filter=@hotelos/api",
    "dev:executive": "turbo run dev --filter=@hotelos/executive",
    "dev:admin": "turbo run dev --filter=@hotelos/admin",
    "dev:guest": "turbo run dev --filter=@hotelos/guest",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "test": "turbo run test",
    "qa": "pnpm install --frozen-lockfile && pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.64.0"
  }
}
