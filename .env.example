NODE_ENV=development
API_PORT=3001
LOG_LEVEL=info
JWT_ACCESS_SECRET=change-me-access-dev-only
JWT_REFRESH_SECRET=change-me-refresh-dev-only
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600
## Local dev: keep the file: URL (same on-disk sqlite file as before).
## Production: point at a hosted Turso DB, e.g. libsql://hotelos-prod.turso.io
DATABASE_URL=file:.data/hotelos.sqlite
## Required only when DATABASE_URL is a libsql:// (Turso) URL
DATABASE_AUTH_TOKEN=
RECORDINGS_PATH=.data/recordings
## Optional: Vercel Blob token for durable recordings on Vercel (leave empty locally)
BLOB_READ_WRITE_TOKEN=
## Optional: enables POST /v1/cron/* (Vercel Cron Authorization: Bearer …)
CRON_SECRET=
## Optional: Sentry (or GlitchTip) DSN for API — leave empty to disable
SENTRY_DSN=
SENTRY_ENVIRONMENT=
## Local: three Vite apps. Production API: add https://*.vercel.app (or exact URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,https://*.vercel.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/trust/oauth/google/callback
GOOGLE_POST_LOGIN_REDIRECT=http://localhost:5173/
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=HotelOS AI
## AI Gateway — leave empty for deterministic provider; set key for OpenAI-compatible LLM
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://api.openai.com/v1
AI_GATEWAY_MODEL=gpt-4o-mini
