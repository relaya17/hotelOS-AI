NODE_ENV=development
API_PORT=3001
LOG_LEVEL=info
JWT_ACCESS_SECRET=change-me-access-dev-only
JWT_REFRESH_SECRET=change-me-refresh-dev-only
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600
## Local dev: keep the file: URL (same on-disk sqlite file as before).
## Production: point at a hosted Turso DB, e.g. libsql://hotelos-prod.turso.io
DATABASE_URL=file:.data/hotelos.sqlite
## Required only when DATABASE_URL is a libsql:// (Turso) URL
DATABASE_AUTH_TOKEN=
RECORDINGS_PATH=.data/recordings
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/trust/oauth/google/callback
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=HotelOS AI
